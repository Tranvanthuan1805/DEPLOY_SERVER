generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                 Int                 @id @default(autoincrement())
  email              String              @unique
  passwordHash       String
  fullName           String
  avatarUrl          String?
  role               Role                @default(STUDENT)
  isActive           Boolean             @default(true)
  googleId           String?             @unique
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  isPro              Boolean             @default(false)
  emailVerified      Boolean             @default(false)
  onboardingComplete Boolean             @default(true)
  admin              Admin?
  notifications      Notification[]
  roleChangeRequests RoleChangeRequest[]
  student            Student?
  teacher            Teacher?

  // Forum Relations
  forumPosts         ForumPost[]
  forumComments      ForumComment[]
  forumReactions     ForumReaction[]
  moderatedCategories ForumCategory[]     @relation("CategoryModerators")
  createdGroups      StudyGroup[]        @relation("GroupCreator")
  groupMemberships   StudyGroupMember[]
  announcements      GroupAnnouncement[]
  reviewedResources  ResourceShare[]     @relation("ReviewedResources")
  reputations        ReputationHistory[]
  badges             UserBadge[]
  gamification       UserGamification?
  reportsSubmitted   ForumReport[]       @relation("Reporter")
  reportsResolved    ForumReport[]       @relation("Resolver")
  auditLogs          ForumAuditLog[]
}

model Student {
  userId       Int           @id
  subjectGroup String
  chatMessages ChatMessage[]
  enrollments  Enrollment[]
  reviews      Review[]
  roadmap      Roadmap?
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  testAttempts TestAttempt[]
}

model Teacher {
  userId     Int      @id
  isApproved Boolean  @default(false)
  bio        String?
  courses    Course[]
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Admin {
  userId Int  @id
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Course {
  id           Int          @id @default(autoincrement())
  title        String
  description  String
  subject      String
  subjectGroup String
  price        Float
  thumbnailUrl String?
  isPublished  Boolean      @default(false)
  isApproved   Boolean      @default(false)
  teacherId    Int
  teacher      Teacher      @relation(fields: [teacherId], references: [userId], onDelete: Cascade)
  enrollments  Enrollment[]
  lessons      Lesson[]
  reviews      Review[]
}

model Lesson {
  id        Int        @id @default(autoincrement())
  courseId  Int
  title     String
  order     Int
  videoUrl  String?
  content   String?
  duration  String
  documents Document[]
  course    Course     @relation(fields: [courseId], references: [id], onDelete: Cascade)
}

model Enrollment {
  id            Int      @id @default(autoincrement())
  studentId     Int
  courseId      Int
  paidAt        DateTime @default(now())
  transactionId String   @unique
  course        Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  student       Student  @relation(fields: [studentId], references: [userId], onDelete: Cascade)
}

model Question {
  id             Int                 @id @default(autoincrement())
  content        String
  options        Json
  correctAnswer  String
  explanation    String?
  subject        String
  topic          String
  difficulty     Difficulty          @default(MEDIUM)
  createdBy      Int
  examQuestions  ExamQuestion[]
  attemptAnswers TestAttemptAnswer[]
}

model Exam {
  id            Int            @id @default(autoincrement())
  title         String
  subject       String
  subjectGroup  String
  duration      Int
  isPublic      Boolean        @default(false)
  createdBy     Int
  examQuestions ExamQuestion[]
  attempts      TestAttempt[]
}

model ExamQuestion {
  examId     Int
  questionId Int
  order      Int
  exam       Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@id([examId, questionId])
}

model TestAttempt {
  id             Int                 @id @default(autoincrement())
  studentId      Int
  examId         Int
  score          Float
  startedAt      DateTime            @default(now())
  submittedAt    DateTime?
  aiFeedback     Json?
  exam           Exam                @relation(fields: [examId], references: [id], onDelete: Cascade)
  student        Student             @relation(fields: [studentId], references: [userId], onDelete: Cascade)
  attemptAnswers TestAttemptAnswer[]
}

model TestAttemptAnswer {
  id             Int         @id @default(autoincrement())
  attemptId      Int
  questionId     Int
  selectedAnswer String
  isCorrect      Boolean
  attempt        TestAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  question       Question    @relation(fields: [questionId], references: [id], onDelete: Cascade)
}

model Roadmap {
  studentId   Int      @id
  content     Json
  generatedAt DateTime @default(now())
  student     Student  @relation(fields: [studentId], references: [userId], onDelete: Cascade)
}

model ChatMessage {
  id        Int      @id @default(autoincrement())
  studentId Int
  role      String
  content   String
  roomId    String
  createdAt DateTime @default(now())
  student   Student  @relation(fields: [studentId], references: [userId], onDelete: Cascade)
}

model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int
  title     String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Review {
  id        Int      @id @default(autoincrement())
  courseId  Int
  studentId Int
  rating    Int
  comment   String?
  createdAt DateTime @default(now())
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  student   Student  @relation(fields: [studentId], references: [userId], onDelete: Cascade)
}

model Document {
  id         Int      @id @default(autoincrement())
  title      String
  fileUrl    String
  fileType   String
  lessonId   Int
  uploadedBy Int
  createdAt  DateTime @default(now())
  lesson     Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
}

enum Role {
  GUEST
  STUDENT
  TEACHER
  ADMIN
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

enum OtpPurpose {
  REGISTRATION
  PASSWORD_RESET
  EMAIL_CHANGE
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
}

model OtpVerification {
  id          Int        @id @default(autoincrement())
  email       String
  otpHash     String
  purpose     OtpPurpose @default(REGISTRATION)
  payload     Json?
  attempts    Int        @default(0)
  maxAttempts Int        @default(5)
  expiresAt   DateTime
  createdAt   DateTime   @default(now())
  isUsed      Boolean    @default(false)

  @@index([email, purpose])
}

model RoleChangeRequest {
  id            Int           @id @default(autoincrement())
  userId        Int
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  currentRole   Role
  requestedRole Role
  reason        String?
  status        RequestStatus @default(PENDING)
  reviewedBy    Int?
  reviewedAt    DateTime?
  createdAt     DateTime      @default(now())

  @@index([userId, status])
}

// =========================================================================
// FORUM SYSTEM MODEL EXTENSIONS
// =========================================================================

enum PostType {
  GENERAL
  QA
  RESOURCE
}

enum GroupRole {
  CREATOR
  ADMIN
  MEMBER
}

enum ResourceStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ReputationAction {
  POST_CREATED
  COMMENT_CREATED
  UPVOTE_RECEIVED
  DOWNVOTE_RECEIVED
  ACCEPTED_ANSWER
  DAILY_STREAK
  RESOURCE_DOWNLOADED
}

enum BadgeCategory {
  POSTING
  ANSWERS
  RESOURCE_SHARING
  REPUTATION
  SPECIAL
}

enum ReportStatus {
  PENDING
  RESOLVED
  DISMISSED
}

model ForumCategory {
  id             Int             @id @default(autoincrement())
  name           String
  slug           String          @unique
  description    String?
  parentId       Int?
  parent         ForumCategory?  @relation("CategoryNesting", fields: [parentId], references: [id], onDelete: Cascade)
  subCategories  ForumCategory[] @relation("CategoryNesting")
  allowedRoles   Role[]          @default([STUDENT, TEACHER, ADMIN])
  posts          ForumPost[]
  moderators     User[]          @relation("CategoryModerators")
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([parentId])
}

model ForumPost {
  id             Int             @id @default(autoincrement())
  title          String
  content        String          @db.Text
  slug           String          @unique
  postType       PostType        @default(GENERAL)
  categoryId     Int
  category       ForumCategory   @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  authorId       Int
  author         User            @relation(fields: [authorId], references: [id], onDelete: Cascade)
  
  isPinned       Boolean         @default(false)
  isArchived     Boolean         @default(false)
  isDraft        Boolean         @default(false)
  scheduledAt    DateTime?
  
  difficulty     Difficulty?
  viewsCount     Int             @default(0)
  
  comments       ForumComment[]
  reactions      ForumReaction[]
  tags           ForumTag[]      @relation("PostTags")
  resource       ResourceShare?
  studyGroupId   Int?
  studyGroup     StudyGroup?     @relation(fields: [studyGroupId], references: [id], onDelete: SetNull)
  reports        ForumReport[]
  
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([categoryId])
  @@index([authorId])
  @@index([postType])
}

model ForumComment {
  id             Int             @id @default(autoincrement())
  postId         Int
  post           ForumPost       @relation(fields: [postId], references: [id], onDelete: Cascade)
  parentId       Int?
  parent         ForumComment?   @relation("CommentNesting", fields: [parentId], references: [id], onDelete: Cascade)
  replies        ForumComment[]  @relation("CommentNesting")
  authorId       Int
  author         User            @relation(fields: [authorId], references: [id], onDelete: Cascade)
  content        String          @db.Text
  
  isSolution     Boolean         @default(false)
  
  reactions      ForumReaction[]
  reports        ForumReport[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([postId])
  @@index([parentId])
  @@index([authorId])
}

model ForumReaction {
  id             Int             @id @default(autoincrement())
  userId         Int
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  postId         Int?
  post           ForumPost?      @relation(fields: [postId], references: [id], onDelete: Cascade)
  commentId      Int?
  comment        ForumComment?   @relation(fields: [commentId], references: [id], onDelete: Cascade)
  
  type           String
  createdAt      DateTime        @default(now())

  @@unique([userId, postId, type])
  @@unique([userId, commentId, type])
  @@index([postId])
  @@index([commentId])
}

model ForumTag {
  id             Int             @id @default(autoincrement())
  name           String          @unique
  slug           String          @unique
  posts          ForumPost[]     @relation("PostTags")
}

model StudyGroup {
  id             Int                @id @default(autoincrement())
  name           String
  description    String?            @db.Text
  avatarUrl      String?
  isPrivate      Boolean            @default(false)
  creatorId      Int
  creator        User               @relation("GroupCreator", fields: [creatorId], references: [id])
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  
  members        StudyGroupMember[]
  posts          ForumPost[]
  announcements  GroupAnnouncement[]
}

model StudyGroupMember {
  id             Int             @id @default(autoincrement())
  groupId        Int
  group          StudyGroup      @relation(fields: [groupId], references: [id], onDelete: Cascade)
  userId         Int
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  role           GroupRole       @default(MEMBER)
  joinedAt       DateTime        @default(now())

  @@unique([groupId, userId])
  @@index([userId])
}

model GroupAnnouncement {
  id             Int             @id @default(autoincrement())
  groupId        Int
  group          StudyGroup      @relation(fields: [groupId], references: [id], onDelete: Cascade)
  title          String
  content        String          @db.Text
  authorId       Int
  author         User            @relation(fields: [authorId], references: [id])
  createdAt      DateTime        @default(now())
}

model ResourceShare {
  id             Int             @id @default(autoincrement())
  postId         Int             @unique
  post           ForumPost       @relation(fields: [postId], references: [id], onDelete: Cascade)
  fileUrl        String
  fileType       String
  fileSize       Int
  downloadCount  Int             @default(0)
  
  ratingSum      Int             @default(0)
  ratingCount    Int             @default(0)
  version        Int             @default(1)
  status         ResourceStatus  @default(PENDING)
  
  reviewedById   Int?
  reviewedBy     User?           @relation("ReviewedResources", fields: [reviewedById], references: [id])
  reviewedAt     DateTime?
  
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([status])
}

model ReputationHistory {
  id             Int              @id @default(autoincrement())
  userId         Int
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  points         Int
  action         ReputationAction
  referenceId    String?
  createdAt      DateTime         @default(now())

  @@index([userId])
  @@index([createdAt])
}

model Badge {
  id             Int             @id @default(autoincrement())
  name           String          @unique
  description    String
  iconUrl        String
  category       BadgeCategory   @default(POSTING)
  criteria       Json
  users          UserBadge[]
}

model UserBadge {
  userId         Int
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  badgeId        Int
  badge          Badge           @relation(fields: [badgeId], references: [id], onDelete: Cascade)
  unlockedAt     DateTime        @default(now())

  @@id([userId, badgeId])
}

model UserGamification {
  userId            Int             @id
  user              User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  level             Int             @default(1)
  xp                Int             @default(0)
  streakDays        Int             @default(0)
  lastActiveDate    DateTime?
  milestonesReached Json?
  
  updatedAt         DateTime        @updatedAt
}

model ForumReport {
  id             Int             @id @default(autoincrement())
  reporterId     Int
  reporter       User            @relation("Reporter", fields: [reporterId], references: [id], onDelete: Cascade)
  postId         Int?
  post           ForumPost?      @relation(fields: [postId], references: [id], onDelete: Cascade)
  commentId      Int?
  comment        ForumComment?   @relation(fields: [commentId], references: [id], onDelete: Cascade)
  reason         String
  status         ReportStatus    @default(PENDING)
  
  resolvedById   Int?
  resolvedBy     User?           @relation("Resolver", fields: [resolvedById], references: [id])
  resolvedAt     DateTime?
  resolutionNotes String?
  
  createdAt      DateTime        @default(now())

  @@index([status])
}

model ForumAuditLog {
  id             Int             @id @default(autoincrement())
  actorId        Int
  actor          User            @relation(fields: [actorId], references: [id])
  action         String
  targetId       String
  details        String?
  ipAddress      String?
  createdAt      DateTime        @default(now())
}

